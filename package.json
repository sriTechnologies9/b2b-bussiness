{
  "name": "localconnect-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Root workspace management for LocalConnect",
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "db:migrate": "npx prisma migrate dev --name init --schema=server/prisma/schema.prisma",
    "db:seed": "npm run prisma:seed --prefix server",
    "install:all": "npm install --prefix server && npm install --prefix client --legacy-peer-deps"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
