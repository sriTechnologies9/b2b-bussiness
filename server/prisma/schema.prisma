datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  phone        String?
  password     String        // Standard bcrypt/mock password
  role         String        @default("CUSTOMER") // CUSTOMER, OWNER, ADMIN
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  businesses   Business[]
  reviews      Review[]
  subscription Subscription?
  rfqs         Rfq[]
  dealerRequests DealerRequest[]
  follows      Follow[]
}

model Business {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  slug        String     @unique
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  description String
  address     String
  city        String
  state       String
  latitude    Float
  longitude   Float
  status      String     @default("PENDING") // PENDING, VERIFIED, REJECTED
  phone       String
  email       String
  whatsapp    String?
  website     String?
  hours       String     // JSON string representing working hours
  gallery     String     // Comma-separated or JSON list of image URLs
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  leads       Lead[]
  reviews     Review[]
  proposals   Proposal[]
  products    Product[]
  follows     Follow[]
}

model Category {
  id         String     @id @default(uuid())
  name       String     @unique
  slug       String     @unique
  icon       String     // Lucide icon name (e.g. "Utensils", "Wrench", etc.)
  businesses Business[]
  rfqs       Rfq[]
}

model Lead {
  id           String   @id @default(uuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName String
  phone        String
  message      String
  status       String   @default("NEW") // NEW, CONTACTED, CONVERTED, CLOSED
  score        String   @default("WARM") // HOT, WARM, COLD
  scoreReason  String?  // Reason generated by AI
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Review {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
}

model Subscription {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       String   @default("FREE") // FREE, BASIC, PRO, PREMIUM
  startDate  DateTime @default(now())
  expiryDate DateTime
}

model Rfq {
  id           String     @id @default(uuid())
  customerId   String
  customer     User       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title        String
  message      String
  budget       Float?
  city         String
  status       String     @default("OPEN") // OPEN, CLOSED
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  proposals    Proposal[]
}

model Proposal {
  id         String   @id @default(uuid())
  rfqId      String
  rfq        Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  price      Float
  message    String
  status     String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Product {
  id            String   @id @default(uuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name          String
  description   String
  price         Float
  image         String?
  isOffer       Boolean  @default(false)
  offerDiscount String?  // Optional discount tag like "10% OFF"
  subCategory   String   @default("General")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DealerRequest {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName   String
  categoryName   String
  contactEmail   String
  contactPhone   String
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  generatedEmail String?
  generatedPass  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Follow {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, businessId])
}

